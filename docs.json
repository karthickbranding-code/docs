{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "YodaEdge",
  "colors": {
    "primary": "#2776ea",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://industry-ai.com.com/blog",
          "icon": "newspaper",
          "color": {
            "light": "#0e63fd",
            "dark": "#0e63fd"
          }
        }
      ]
    },
    "products": [
      {
        "product": "YodaEdge",
        "icon": "airplay-audio",
        "color": {
          "light": "#00a2ff",
          "dark": "#00a2ff"
        },
        "description": "The Factory Intelligence",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "development"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/yoda_logo.png",
    "dark": "/images/yoda_logo.png",
    "href": "https://yodaedge.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@yodaedge.com"
      },
      {
        "href": "https://industry-ai.com",
        "label": "Industry AI"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/karthick.branding",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "background": {
    "color": {
      "light": "#eefeff",
      "dark": "#5a5a5a"
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "fonts": {
    "family": "Montserrat"
  },
  "description": "documentation of YodaEdge Products"
}
